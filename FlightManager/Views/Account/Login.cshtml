@model FlightManager.Models.LoginViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card" style="max-width:420px;margin:60px auto;padding:24px;">
    <h1 style="text-align:center">Sign in</h1>

    <form asp-action="Login" method="post" novalidate>
        <div style="display:flex;flex-direction:column;gap:12px;">
            <div>
                <label asp-for="Email"></label>
                <input asp-for="Email" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.05);color:white;" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.05);color:white;" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div style="text-align:center;margin-top:8px;">
                <button type="submit" style="padding:12px 30px;border-radius:30px;background:linear-gradient(45deg,#ff9966,#ff5e62);border:none;color:white;font-weight:600;">Login</button>
            </div>

            <div style="text-align:center;color:rgba(255,255,255,0.8);">
                <a asp-controller="Account" asp-action="Register" style="color:#ffd166;">Create an account</a>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}