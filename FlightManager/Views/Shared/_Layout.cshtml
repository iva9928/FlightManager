@using Microsoft.AspNetCore.Identity
@using FlightManager.Data.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Flight Manager</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>

        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(120deg,#1e3c72,#2a5298,#4facfe);
            min-height: 100vh;
        }

        .plane {
            position: fixed;
            font-size: 60px;
            top: 20%;
            left: -120px;
            animation: fly 18s linear infinite;
        }

        keyframes fly {
            0%

        {
            left: -120px;
            transform: rotate(10deg);
        }

        50% {
            top: 30%;
        }

        100% {
            left: 110%;
            top: 10%;
            transform: rotate(5deg);
        }

        }

        .cloud {
            position: fixed;
            font-size: 90px;
            opacity: 0.15;
            animation: cloudMove 60s linear infinite;
        }

        .cloud1 {
            top: 10%;
            left: -200px;
        }

        .cloud2 {
            top: 50%;
            left: -300px;
        }

        keyframes cloudMove {
            0%

        {
            left: -300px;
        }

        100% {
            left: 120%;
        }

        }

        nav {
            display: flex;
            justify-content: space-between;
            padding: 20px 60px;
            background: rgba(255,255,255,0.1);
        }

            nav a {
                color: white;
                text-decoration: none;
                margin: 0 10px;
            }

        .right-nav {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* dropdowns: white text on dark-blue background to match site palette */
        select, option {
            color: #fff !important;
            background-color: #1e3c72 !important; /* dark blue */
        }

        .right-nav span {
            color: white;
        }

        .container {
            padding: 40px;
        }

        .card {
            background: rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 25px;
            color: white;
        }

        button {
            padding: 8px 15px;
            border-radius: 20px;
            border: none;
            background: #ff5e62;
            color: white;
            cursor: pointer;
        }

    </style>

</head>

<body>

    <div class="plane">✈️</div>
    <div class="cloud cloud1">☁️</div>
    <div class="cloud cloud2">☁️</div>

    <nav>

        <div>
            <a href="/">Flight Manager</a>
        </div>

        <div class="right-nav">

            <a href="/Flights">Flights</a>
                @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                {
                    <a href="/Users">Users</a>
                }

            @if (SignInManager.IsSignedIn(User))
            {
                if (User.IsInRole("Admin"))
                {
                    <a href="/Flights/Create">Add Flight</a>
                }

                if (User.IsInRole("Employee"))
                {
                    <a href="/Reservations">All Reservations</a>
                }

                if (User.IsInRole("User"))
                {
                    <a href="/Reservations/MyReservations">My Reservations</a>
                }

                <span>👤 @User.Identity?.Name</span>

                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit">Logout</button>
                </form>
            }
            else
            {
                <a href="/Account/Login">Login</a>
                <a href="/Account/Register">Register</a>
            }

        </div>

    </nav>

    @if (TempData["Success"] != null)
    {
        <div style="text-align:center; color:white;">
            ✔ @TempData["Success"]
        </div>
    }

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>