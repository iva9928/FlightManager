@model IEnumerable<FlightManager.Models.ReservationListViewModel>

<h2>✈️ Reservations</h2>

@if (TempData["Success"] != null)
{
    <div style="background-color: #4CAF50; color: white; padding: 10px; border-radius: 10px; margin-bottom: 10px;">
        @TempData["Success"]
    </div>
}

<table class="table mt-3">
    <thead>
        <tr>
            <th>Email</th>
            <th>Flight</th>
            <th>Passengers</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Email</td>
                <td>@r.FlightId</td>
                <td>@r.PassengersCount</td>

                <td>
                    @if (r.Status == "Approved")
                    {
                        <span style="color:lightgreen;">✔ Approved</span>
                    }
                    else if (r.Status == "Rejected")
                    {
                        <span style="color:red;">✖ Rejected</span>
                    }
                    else
                    {
                        <span style="color:orange;">⏳ Pending</span>
                    }
                </td>

                <td>

                    <a asp-action="Details" asp-route-id="@r.Id">Details</a>

                    <!-- 🔥 EMPLOYEE BUTTON -->
                    @if (User.IsInRole("Employee") && r.Status == "Pending")
                    {
                        <form asp-action="Confirm" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button style="background:green; color:white;">Approve</button>
                        </form>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>