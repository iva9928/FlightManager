@model IEnumerable<FlightManager.Models.FlightListViewModel>

<div class="card" style="padding:30px; border-radius:20px; background: linear-gradient(135deg,#2c3e50,#4ca1af); color:white;">

    <h1 style="margin-bottom:20px;">✈ Flights</h1>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Flights" asp-action="Create">
            <button style="background:#ff6b6b; color:white; padding:10px 20px; border:none; border-radius:20px; margin-bottom:20px;">
                Add Flight
            </button>
        </a>
    }

    <table style="width:100%; border-collapse:separate; border-spacing:0 10px;">

        <thead>
            <tr style="text-align:left;">
                <th>From</th>
                <th>To</th>
                <th>Departure</th>
                <th>Duration</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var flight in Model)
            {
                <tr style="background: rgba(255,255,255,0.1); border-radius:15px;">

                    <td>🌍 @flight.FromLocation</td>

                    <td>🛬 @flight.ToLocation</td>

                    <td>@flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>

                    <td>@flight.Duration</td>

                    <td style="display:flex; gap:10px;">

                        <!-- Details -->
                        <a asp-controller="Flights" asp-action="Details" asp-route-id="@flight.Id" style="padding:8px 15px;border-radius:20px;background:#ff6b6b;color:white;text-decoration:none;display:inline-block;">Details</a>

                        <!-- Edit (Admin only) -->
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Flights" asp-action="Edit" asp-route-id="@flight.Id" style="padding:8px 15px;border-radius:20px;background:#ff6b6b;color:white;text-decoration:none;display:inline-block;">Edit</a>
                        }

                        <!-- ✅ РЕЗЕРВАЦИЯ (FIXED) -->
                        <a asp-controller="Reservations" asp-action="Create" asp-route-flightId="@flight.Id" style="padding:8px 15px;border-radius:20px;background:#27ae60;color:white;text-decoration:none;display:inline-block;">✈ Reserve</a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>